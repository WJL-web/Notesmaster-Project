    <!-- ==================== 复数资源（搜索结果标题） ==================== -->

    <!--
        搜索结果标题（支持单复数形式）
        %1$s：搜索结果数量
        %2$s：搜索关键词
        例如："3 條符合”筆記“的搜尋結果"
    -->
    <plurals name="search_results_title">
        <item quantity="other"><xliff:g id="NUMBER">%1$s</xliff:g> 條符合”<xliff:g id="SEARCH">%2$s</xliff:g>“的搜尋結果</item>
    </plurals>

