<?xml version="1.0" encoding="utf-8"?>

<!--
  字符串数组资源配置文件
  作用：
  1. 定义便签【备份/导出】的文本格式
  2. 定义【分享方式】菜单数组
-->

<!-- Copyright (c) 2010-2011, The MiCode Open Source Community (www.micode.net) -->
<resources>

    <!-- ====================== 便签导出/备份格式 ====================== -->
    <string-array name="format_for_exported_note">
        <item>-%s</item>      <!-- 文件夹名称格式（前缀：-） -->
        <item>--%s</item>     <!-- 文件夹下便签：日期格式（前缀：-） -->
        <item>--%s</item>     <!-- 普通便签：日期格式（前缀：-） -->
        <item>--%s</item>     <!-- 便签内容格式（前缀：-） -->
    </string-array>

    <!-- ====================== 分享方式菜单 ====================== -->
    <string-array name="menu_share_ways">
        <item>Messaging</item>  <!-- 短信分享 -->
        <item>Email</item>      <!-- 邮件分享 -->
    </string-array>

</resources>